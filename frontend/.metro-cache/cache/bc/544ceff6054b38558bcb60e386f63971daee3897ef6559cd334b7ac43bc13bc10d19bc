{"dependencies":[],"output":[{"data":{"code":"__d(function (global, require, _$$_IMPORT_DEFAULT, _$$_IMPORT_ALL, module, exports, _dependencyMap) {\n  \"use strict\";\n\n  Object.defineProperty(exports, '__esModule', {\n    value: true\n  });\n  Object.defineProperty(exports, \"fichesActionAdmin\", {\n    enumerable: true,\n    get: function () {\n      return fichesActionAdmin;\n    }\n  });\n  // Fiches 26-37 : L'action administrative locale - Contenu complet extrait du PDF\n\n  const fichesActionAdmin = [{\n    id: 26,\n    title: \"Le domaine des collectivités territoriales\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Le domaine public\",\n      text: \"Comprend les biens appartenant aux personnes publiques, affectés à l'usage direct du public ou aux besoins d'un service public (ayant fait l'objet d'un aménagement indispensable).\\n\\nCaractéristiques :\\n• Inaliénabilité : ne peut être vendu tant qu'il reste dans le domaine public\\n• Imprescriptibilité : ne peut être acquis par prescription\\n• Insaisissabilité : ne peut faire l'objet d'une saisie\\n\\nLa délimitation est opérée unilatéralement par l'administration.\\n\\nExemples : voirie, bâtiments publics, places, jardins publics, réseaux d'eau et d'assainissement.\"\n    }, {\n      title: \"2. Le domaine privé\",\n      text: \"Comprend les biens n'appartenant pas au domaine public. Soumis au droit privé.\\n\\nPeut être aliéné, prescrit, donné en concession.\\n\\nExemples : forêts communales, immeubles de rapport, terrains non affectés à un service public.\\n\\nLes personnes publiques propriétaires bénéficient toutefois de l'insaisissabilité de leurs biens, même du domaine privé.\"\n    }]\n  }, {\n    id: 27,\n    title: \"Les services publics locaux\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Notion de service public\",\n      text: \"Activité d'intérêt général assurée ou assumée par une personne publique.\\n\\nDistinction :\\n• SPA (Service Public Administratif) : soumis au droit administratif\\n• SPIC (Service Public Industriel et Commercial) : soumis majoritairement au droit privé\"\n    }, {\n      title: \"2. Les grands principes\",\n      text: \"• Continuité : le service doit fonctionner de manière régulière et continue\\n• Égalité : traitement identique des usagers placés dans la même situation\\n• Mutabilité (adaptation) : le service doit s'adapter à l'évolution des besoins et des techniques\\n• Transparence : information des usagers sur le fonctionnement\"\n    }, {\n      title: \"3. Modes de gestion\",\n      text: \"Gestion intégrée :\\n• Régie directe : la collectivité gère directement le service\\n• Régie autonome : dotée de l'autonomie financière\\n• Régie personnalisée : dotée de la personnalité morale (EPIC)\\n• Quasi-régie (« in house ») : contrat avec un organisme contrôlé comme un service propre\\n\\nGestion externalisée :\\n• Marché de service public : prestation payée par la collectivité\\n• Délégation de service public (DSP) : le délégataire est rémunéré substantiellement par les résultats de l'exploitation\\n• Concession, affermage, régie intéressée\"\n    }, {\n      title: \"4. Procédure de DSP\",\n      text: \"Publicité obligatoire : avis d'appel public à la concurrence.\\n\\nExamen des candidatures : critères de capacité professionnelle, technique et financière.\\n\\nNégociation : libre avec un ou plusieurs candidats.\\n\\nChoix : le délégataire est choisi sur la base de l'offre la plus avantageuse.\\n\\nApprobation : l'assemblée délibérante se prononce sur le choix du délégataire et le contrat.\\n\\nDurée : limitée, proportionnée aux investissements demandés.\"\n    }]\n  }, {\n    id: 28,\n    title: \"Les actes des collectivités territoriales\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Deux catégories d'actes\",\n      text: \"Actes administratifs unilatéraux :\\n• Actes réglementaires : portée générale et impersonnelle (ex: règlement intérieur, PLU)\\n• Actes individuels : visent une personne nommément désignée (ex: permis de construire, nomination)\\n\\nContrats : engagent deux ou plusieurs parties (marchés publics, DSP, baux).\"\n    }, {\n      title: \"2. Compétence\",\n      text: \"Principe : l'assemblée délibérante adopte les actes et contrats.\\n\\nExceptions :\\n• L'exécutif dispose de pouvoirs propres (police)\\n• L'assemblée peut déléguer certaines compétences à l'exécutif ou à la commission permanente\\n• Exemples de délégations possibles : marchés de montant limité, actions en justice, emprunts, aliénations immobilières\"\n    }, {\n      title: \"3. Entrée en vigueur et contrôle\",\n      text: \"Les actes sont exécutoires après :\\n1) Publication ou notification au destinataire\\n2) Transmission au représentant de l'État (pour les actes soumis au contrôle de légalité)\\n\\nLe préfet exerce un contrôle de légalité a posteriori et peut déférer les actes au tribunal administratif.\"\n    }]\n  }, {\n    id: 29,\n    title: \"L'acte administratif unilatéral\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Caractéristiques\",\n      text: \"C'est un acte émanant d'une autorité administrative qui modifie unilatéralement l'ordonnancement juridique, sans le consentement des destinataires.\\n\\nTypologie :\\n• Actes réglementaires : portée générale et impersonnelle\\n• Actes individuels : concernent une ou plusieurs personnes nommément désignées\\n• Actes décisoires / non décisoires (mesures d'ordre intérieur, circulaires, directives)\"\n    }, {\n      title: \"2. Régime juridique\",\n      text: \"Forme : motivation obligatoire pour les décisions individuelles défavorables.\\n\\nProcédure : respect du contradictoire pour certaines décisions défavorables.\\n\\nPublicité : publication (actes réglementaires) ou notification (actes individuels).\\n\\nRetrait et abrogation :\\n• Actes créateurs de droits : retrait possible dans un délai de 4 mois (si illégaux)\\n• Actes non créateurs de droits : retrait ou abrogation possible à tout moment\"\n    }]\n  }, {\n    id: 30,\n    title: \"Le contrat administratif\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Identification du contrat administratif\",\n      text: \"Critère organique : au moins une personne publique partie au contrat.\\n\\nCritères alternatifs :\\n• Clauses exorbitantes du droit commun\\n• Participation à l'exécution du service public\\n• Qualification législative (marchés publics, DSP, contrats de partenariat)\"\n    }, {\n      title: \"2. Régime juridique\",\n      text: \"Prérogatives de l'administration :\\n• Pouvoir de direction et de contrôle\\n• Pouvoir de modification unilatérale (dans l'intérêt du service)\\n• Pouvoir de sanction\\n• Pouvoir de résiliation unilatérale pour motif d'intérêt général\\n\\nDroits du cocontractant :\\n• Droit au paiement du prix\\n• Droit à l'équilibre financier (théorie de l'imprévision, fait du prince, sujétions imprévues)\"\n    }]\n  }, {\n    id: 31,\n    title: \"Le principe de légalité\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Contenu du principe\",\n      text: \"L'administration doit agir conformément au droit. La hiérarchie des normes s'impose :\\n\\n1) Constitution et bloc de constitutionnalité\\n2) Traités et droit international / droit de l'UE\\n3) Lois organiques et lois ordinaires\\n4) Principes généraux du droit (PGD)\\n5) Actes réglementaires (décrets, arrêtés)\\n\\nL'administration doit respecter :\\n• La légalité externe : compétence, forme, procédure\\n• La légalité interne : objet, motifs, but\\n\\nLe juge administratif sanctionne les illégalités par l'annulation (recours pour excès de pouvoir).\"\n    }, {\n      title: \"2. Limites au principe de légalité\",\n      text: \"Circonstances exceptionnelles : en cas de crise grave (guerre, catastrophe), l'administration peut prendre des mesures normalement illégales pour assurer la continuité des services publics.\\n\\nThéorie des circonstances exceptionnelles (jurisprudence Heyriès, 1918) : le juge vérifie que les circonstances étaient réellement exceptionnelles et que les mesures étaient nécessaires et proportionnées.\\n\\nÉtat d'urgence : régime légal permettant des mesures restrictives des libertés (assignations à résidence, perquisitions administratives).\"\n    }]\n  }, {\n    id: 32,\n    title: \"Le contrôle de légalité\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Champ d'application\",\n      text: \"Depuis la loi du 2 mars 1982, le contrôle a priori (tutelle) a été remplacé par un contrôle a posteriori.\\n\\nActes soumis à transmission obligatoire au préfet :\\n• Délibérations des assemblées\\n• Décisions réglementaires et individuelles du maire/président\\n• Conventions relatives aux marchés et DSP\\n• Décisions de police\\n• Permis de construire et autres autorisations d'urbanisme\\n\\nAutres actes : exécutoires dès publication/notification, sans transmission obligatoire.\"\n    }, {\n      title: \"2. Intervention du préfet\",\n      text: \"Le préfet vérifie la légalité des actes transmis. S'il estime un acte illégal :\\n\\n1) Lettre d'observation : demande de retrait ou de modification (phase amiable)\\n2) Déféré préfectoral : saisine du tribunal administratif pour annulation\\n3) Possibilité de demander la suspension en urgence\\n\\nLe préfet ne contrôle PAS l'opportunité des décisions.\\n\\nRescrit préfectoral : possibilité pour les CT de demander au préfet de prendre formellement position sur la légalité d'un acte avant son adoption.\"\n    }, {\n      title: \"3. Chiffres du contrôle\",\n      text: \"Évolution constante du nombre d'actes transmis (environ 5 millions par an). Le système d'information @CTES facilite la dématérialisation des transmissions.\\n\\nLe taux de déféré préfectoral reste faible (moins de 0,5% des actes transmis), la majorité des problèmes étant résolus en phase amiable.\"\n    }]\n  }, {\n    id: 33,\n    title: \"Les pouvoirs de police du maire\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Police administrative / Police judiciaire\",\n      text: \"Police administrative : préventive, vise à maintenir l'ordre public (avant qu'une infraction ne soit commise).\\n\\nPolice judiciaire : répressive, vise à constater les infractions et en rechercher les auteurs (après commission d'une infraction).\\n\\nLe maire agit tantôt comme autorité de police administrative (pouvoir propre), tantôt comme officier de police judiciaire (au nom de l'État, sous autorité du procureur).\"\n    }, {\n      title: \"2. Police générale / Polices spéciales\",\n      text: \"Police générale : maintien de l'ordre public au sens large (sécurité, tranquillité, salubrité publiques). Composantes de l'ordre public :\\n• Sûreté et commodité du passage (voies publiques)\\n• Tranquillité publique (bruits, rassemblements)\\n• Salubrité publique (hygiène, épidémies)\\n• Depuis 1995 : moralité publique et respect de la dignité humaine\\n\\nPolices spéciales : objets précis définis par la loi :\\n• Police des immeubles menaçant ruine\\n• Police des établissements recevant du public (ERP)\\n• Police de la circulation et du stationnement\\n• Police des funérailles et cimetières\\n• Police de la publicité et enseignes\"\n    }, {\n      title: \"3. Exercice des pouvoirs de police\",\n      text: \"Le maire est la principale autorité de police municipale. Pouvoirs personnels, non délégables au conseil municipal (mais délégables aux adjoints par arrêté).\\n\\nLe préfet peut se substituer au maire en cas de carence (mise en demeure préalable de 48h sauf urgence).\\n\\nPouvoir de police du président d'EPCI : transfert possible pour certaines polices spéciales (voirie, assainissement, déchets, aires d'accueil des gens du voyage).\\n\\nPolice municipale : agents municipaux placés sous l'autorité du maire. Missions de prévention, surveillance et respect du bon ordre.\"\n    }]\n  }, {\n    id: 34,\n    title: \"La police administrative\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Principes généraux\",\n      text: \"La police administrative est l'ensemble des activités de réglementation et de contrôle visant à prévenir les troubles à l'ordre public.\\n\\nAutorités de police : le maire au niveau communal, le préfet au niveau départemental, le Premier ministre au niveau national.\\n\\nProportionnalité : les mesures de police doivent être proportionnées à la menace. Le juge contrôle l'adéquation entre la mesure et le trouble à l'ordre public.\\n\\nConcours de police : quand plusieurs autorités sont compétentes sur le même territoire, l'autorité inférieure peut aggraver la mesure de l'autorité supérieure mais jamais l'atténuer.\"\n    }]\n  }, {\n    id: 35,\n    title: \"La responsabilité administrative\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Responsabilité pour faute\",\n      text: \"\",\n      subsections: [{\n        title: \"1.1. Faute de service\",\n        text: \"La faute de service est une faute commise par un agent dans l'exercice de ses fonctions, qui n'est pas détachable du service.\\n\\nLa collectivité est responsable. L'agent n'est pas personnellement mis en cause.\\n\\nExemples : mauvais entretien de la voirie, erreur dans la délivrance d'un permis de construire, retard dans l'exécution d'un service.\"\n      }, {\n        title: \"1.2. Faute personnelle\",\n        text: \"La faute personnelle est détachable du service : elle révèle les faiblesses, passions ou imprudences de l'agent.\\n\\nL'agent est personnellement responsable devant le juge judiciaire.\\n\\nMais la victime peut aussi poursuivre l'administration si la faute n'est pas dépourvue de tout lien avec le service (cumul de fautes / cumul de responsabilités).\\n\\nLa collectivité qui a indemnisé la victime peut exercer une action récursoire contre l'agent fautif.\"\n      }]\n    }, {\n      title: \"2. Responsabilité sans faute\",\n      text: \"\",\n      subsections: [{\n        title: \"2.1. Responsabilité pour risque\",\n        text: \"L'administration est responsable des dommages causés par des activités, méthodes ou choses dangereuses, même sans faute.\\n\\nExemples : dommages causés par les travaux publics, activités dangereuses, collaborateurs occasionnels du service public.\"\n      }, {\n        title: \"2.2. Responsabilité pour rupture d'égalité devant les charges publiques\",\n        text: \"L'administration peut être responsable si une mesure légale cause un préjudice anormal et spécial à certaines personnes.\\n\\nConditions : le préjudice doit être certain, direct, spécial (touche un nombre limité de personnes) et anormal (d'une gravité suffisante).\"\n      }]\n    }, {\n      title: \"3. Conditions de la responsabilité\",\n      text: \"3 conditions cumulatives :\\n1) Un fait générateur (faute ou fait dommageable)\\n2) Un préjudice (certain, direct, personnel, évaluable en argent)\\n3) Un lien de causalité entre le fait générateur et le préjudice\\n\\nCauses d'exonération : force majeure, fait du tiers, faute de la victime.\"\n    }]\n  }, {\n    id: 36,\n    title: \"Le partenariat public privé\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Les contrats de partenariat\",\n      text: \"Contrat global confiant à un opérateur privé une mission de conception, financement, construction, entretien et exploitation d'un ouvrage ou équipement public.\\n\\nConditions de recours : urgence, complexité du projet, ou bilan avantage-coût favorable.\\n\\nCaractéristiques : paiement étalé dans le temps, partage des risques, critères de performance.\\n\\nDepuis l'ordonnance du 23 juillet 2015, les marchés de partenariat sont intégrés dans le code de la commande publique.\"\n    }]\n  }, {\n    id: 37,\n    title: \"Les délégations de service public des collectivités territoriales\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Définition de la DSP\",\n      text: \"Contrat par lequel une personne morale de droit public confie la gestion d'un service public dont elle a la responsabilité à un délégataire public ou privé, dont la rémunération est substantiellement liée aux résultats de l'exploitation du service.\\n\\nFormes de DSP :\\n• Concession : le concessionnaire construit l'ouvrage et l'exploite à ses risques\\n• Affermage : la collectivité met à disposition les ouvrages, le fermier les exploite\\n• Régie intéressée : la collectivité rémunère le régisseur avec un intéressement aux résultats\"\n    }, {\n      title: \"2. Régime juridique\",\n      text: \"Procédure de passation :\\n1) Délibération de l'assemblée sur le principe de la délégation\\n2) Publicité : avis d'appel public à la concurrence\\n3) Examen des candidatures (capacités)\\n4) Envoi du dossier aux candidats retenus\\n5) Négociation libre avec les candidats\\n6) Choix du délégataire\\n7) Saisine de la commission consultative des services publics locaux\\n8) Approbation par l'assemblée délibérante\\n\\nDurée : limitée, en rapport avec la durée d'amortissement des investissements.\\n\\nContrôle : rapport annuel du délégataire, contrôle de la collectivité, possibilité de résiliation.\"\n    }]\n  }];\n});","lineCount":174,"map":[[7,2,5,0,"Object"],[7,8,5,0],[7,9,5,0,"defineProperty"],[7,23,5,0],[7,24,5,0,"exports"],[7,31,5,0],[8,4,5,0,"enumerable"],[8,14,5,0],[9,4,5,0,"get"],[9,7,5,0],[9,18,5,0,"get"],[9,19,5,0],[10,6,5,0],[10,13,5,0,"fichesActionAdmin"],[10,30,5,0],[11,4,5,0],[12,2,5,0],[13,2,3,0],[15,2,5,7],[15,8,5,13,"fichesActionAdmin"],[15,25,5,39],[15,28,5,42],[15,29,6,2],[16,4,6,4,"id"],[16,6,6,6],[16,8,6,8],[16,10,6,10],[17,4,6,12,"title"],[17,9,6,17],[17,11,6,19],[17,55,6,63],[18,4,6,65,"theme"],[18,9,6,70],[18,11,6,72],[18,26,6,87],[19,4,6,89,"sections"],[19,12,6,97],[19,14,6,99],[19,15,7,4],[20,6,7,6,"title"],[20,11,7,11],[20,13,7,13],[20,35,7,35],[21,6,7,37,"text"],[21,10,7,41],[21,12,7,43],[22,4,7,613],[22,5,7,614],[22,7,8,4],[23,6,8,6,"title"],[23,11,8,11],[23,13,8,13]