{"dependencies":[],"output":[{"data":{"code":"__d(function (global, require, _$$_IMPORT_DEFAULT, _$$_IMPORT_ALL, module, exports, _dependencyMap) {\n  \"use strict\";\n\n  Object.defineProperty(exports, '__esModule', {\n    value: true\n  });\n  Object.defineProperty(exports, \"fichesCollectivites\", {\n    enumerable: true,\n    get: function () {\n      return fichesCollectivites;\n    }\n  });\n  // Fiches 7-25 : Les collectivités locales - Contenu complet extrait du PDF\n\n  const fichesCollectivites = [{\n    id: 7,\n    title: \"Principaux chiffres sur les élus locaux\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Les élus locaux en France\",\n      text: \"La France compte environ 500 000 élus locaux, dont une grande majorité sont des conseillers municipaux (environ 510 000 dans environ 35 000 communes).\\n\\nAutres catégories d'élus :\\n• Conseillers départementaux : environ 4 000\\n• Conseillers régionaux : environ 2 000\\n• Conseillers communautaires : environ 70 000\\n\\nParité : la loi impose la parité dans les scrutins de liste. Le taux de femmes progresse régulièrement dans les assemblées locales.\"\n    }]\n  }, {\n    id: 8,\n    title: \"La participation des citoyens à la vie locale\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. La participation des électeurs aux décisions locales\",\n      text: \"\",\n      subsections: [{\n        title: \"1.1. Le référendum local\",\n        text: \"L'exécutif d'une CT peut proposer à l'assemblée délibérante de soumettre à référendum local tout projet d'acte relevant de ses attributions (sauf actes individuels).\\n\\nL'assemblée délibérante détermine les modalités d'organisation, fixe le jour du scrutin, convoque les électeurs.\\n\\nLe représentant de l'État dispose de 10 jours pour déférer la délibération au TA s'il l'estime illégale.\\n\\nValidité : le projet est adopté si la moitié au moins des électeurs inscrits a voté ET si la majorité des suffrages est réunie. Sinon, valeur seulement consultative.\\n\\nLimites : interdictions en période de renouvellement des assemblées ou de campagne électorale. Pas de second référendum sur le même objet dans un délai d'un an.\"\n      }, {\n        title: \"1.2. La consultation des électeurs pour avis\",\n        text: \"Un cinquième des électeurs (commune) ou un dixième (autres CT) peuvent demander l'organisation d'une consultation.\\n\\nLa décision appartient à l'assemblée délibérante. L'indication que c'est une demande d'avis est obligatoire.\\n\\nLes électeurs répondent par oui ou par non. L'autorité compétente arrête sa décision sur l'affaire.\"\n      }]\n    }, {\n      title: \"2. La participation des habitants à la vie locale\",\n      text: \"\",\n      subsections: [{\n        title: \"2.1. Le conseil de quartier\",\n        text: \"Communes de 80 000 hab. et + : obligation de créer des conseils de quartier. Les communes de 20 000 à 79 999 hab. peuvent en créer.\\n\\nCompétences : consultés par le maire, peuvent faire des propositions. Peuvent être associés à l'élaboration et l'évaluation des actions.\\n\\nBudget participatif : permet aux citoyens non élus de participer à la répartition d'une partie des finances publiques locales.\"\n      }, {\n        title: \"2.2. Le comité consultatif communal\",\n        text: \"Le conseil municipal peut créer des comités consultatifs sur tout problème d'intérêt communal. Ils comprennent des personnes n'appartenant pas au conseil, dont des représentants d'associations.\\n\\nLe maire fixe la composition et désigne le président.\"\n      }, {\n        title: \"2.3. Commission accessibilité handicap\",\n        text: \"Obligatoire dans les communes de 5 000 hab. et + et les EPCI compétents de 5 000 hab. et +.\\n\\nMission : dresser le constat d'accessibilité, établir un rapport annuel, faire des propositions, recenser l'offre de logements accessibles.\"\n      }, {\n        title: \"2.4. Commission consultative des services publics locaux\",\n        text: \"Obligatoire pour les régions, départements, communes de + 10 000 hab., EPCI de + 50 000 hab.\\n\\nExamine chaque année le rapport du président sur l'amélioration des services publics locaux. Consultée sur les projets de DSP, régies autonomes, partenariats.\"\n      }]\n    }]\n  }, {\n    id: 9,\n    title: \"La composition du conseil municipal\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Nombre de conseillers municipaux\",\n      text: \"Le nombre varie de 7 membres (communes < 100 hab.) à 69 membres (communes ≥ 300 000 hab.), selon un tableau fixé par la loi.\\n\\nDepuis la loi de 2019 : dans les communes < 100 hab., le conseil est réputé complet dès lors qu'il compte au moins 5 membres après le second tour.\"\n    }, {\n      title: \"2. Le mode de scrutin\",\n      text: \"\",\n      subsections: [{\n        title: \"2.1. Communes de moins de 1 000 habitants\",\n        text: \"Scrutin plurinominal majoritaire à deux tours.\\n\\nSuffrages décomptés individuellement par candidat (pas par liste).\\n\\n1er tour : majorité absolue + au moins 1/4 des inscrits.\\n2e tour : majorité relative. En cas d'égalité : le plus âgé est élu.\"\n      }, {\n        title: \"2.2. Communes de 1 000 habitants et plus\",\n        text: \"Scrutin de liste à deux tours avec listes paritaires.\\n\\nListes sans adjonction ni suppression de noms ni modification de l'ordre.\\n\\nRépartition : proportionnelle à la plus forte moyenne avec prime majoritaire de 50% à la liste en tête.\\n\\n1er tour : acquis si majorité absolue.\\n2e tour : seuil de 10% des suffrages exprimés pour se présenter. Fusion de listes possible (seuil 5%).\\n\\nLa liste en tête obtient la moitié des sièges (arrondi au supérieur). Les sièges restants sont répartis à la proportionnelle (plus forte moyenne).\\n\\nEn cas de vacance : remplacement par le candidat suivant sur la même liste.\"\n      }]\n    }, {\n      title: \"3. Conditions d'éligibilité et inéligibilité\",\n      text: \"Éligibilité : 18 ans révolus, attache avec la commune (inscrit sur la liste électorale ou au rôle des contributions directes). Ressortissants UE éligibles s'ils sont inscrits sur la liste complémentaire.\\n\\nNul ne peut être candidat dans plus d'une commune ni sur plus d'une liste.\\n\\nCommunes > 500 hab. : maximum 2 ascendants/descendants en ligne directe dans le même conseil.\\n\\nInéligibilité : privation de droits civiques, tutelle/curatelle, condamnation pour comptes de campagne, incompatibilités professionnelles (préfet, sous-préfet dans leur ressort).\\n\\nNon-cumul : un conseiller municipal ne peut détenir qu'un seul autre mandat local.\"\n    }]\n  }, {\n    id: 10,\n    title: \"Le rôle du conseil municipal\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. La clause générale de compétence\",\n      text: \"Le conseil municipal règle par ses délibérations les affaires de la commune. Clause traditionnelle permettant des actions d'intérêt public communal.\\n\\nSeules les communes conservent cette clause (régions et départements l'ont perdue avec la loi NOTRe 2015).\\n\\nDomaines de délibération :\\n• Budget et gestion des services publics communaux\\n• Compte administratif\\n• Création et suppression des emplois communaux\\n• Désignation des représentants dans les organismes extérieurs\\n• Avis et vœux sur tout objet d'intérêt local\"\n    }, {\n      title: \"2. Les attributions spécifiques\",\n      text: \"• Urbanisme : PLU, SCOT, carte communale\\n• Logement : intervention en faveur du logement social, OPAH\\n• Cimetières : création, agrandissement, entretien\\n• Collecte ordures ménagères : enlèvement, organisation\\n• Enseignement 1er degré : bâtiments scolaires (hors enseignants = État)\\n• Eau : accès à la ressource, traitement, distribution\\n• Assainissement : collecte et traitement des eaux usées\\n• Actions culturelles : musées, archives, bibliothèques, archéologie\\n• Action sociale : CCAS, petite enfance, personnes âgées\\n• Voirie communale : chaussées, signalisation, déneigement\\n• Transports publics locaux\\n• Parcs de stationnement\"\n    }]\n  }, {\n    id: 11,\n    title: \"La préparation du conseil municipal\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Fréquence des réunions\",\n      text: \"Minimum une fois par trimestre. Plus fréquemment si le maire le juge utile.\\n\\nConvocation obligatoire sur demande :\\n• Du préfet\\n• Du tiers des membres (communes ≥ 1 000 hab.) ou de la majorité (communes < 1 000 hab.)\\n\\nLe maire doit convoquer dans les 30 jours après réception de la demande motivée.\"\n    }, {\n      title: \"2. Forme de la convocation\",\n      text: \"Doit être écrite, signée du maire (ou des adjoints en cas d'empêchement, sans délégation nécessaire).\\n\\nTransmise de manière dématérialisée ou par écrit sur demande des conseillers.\\n\\nMentionnée au registre des délibérations, affichée ou publiée.\"\n    }, {\n      title: \"3. Contenu de la convocation\",\n      text: \"Éléments obligatoires :\\n• Jour, heure et lieu de la réunion\\n• Ordre du jour (liste des projets de délibération)\\n• Communes ≥ 3 500 hab. : note explicative de synthèse pour chaque point\\n\\nL'ordre du jour est fixé par le maire (compétence discrétionnaire), sauf :\\n• Demande motivée du préfet ou de conseillers\\n• Droit de proposition de chaque conseiller\\n\\nL'absence de note explicative peut entraîner l'annulation de la délibération.\"\n    }, {\n      title: \"4. Délais d'envoi\",\n      text: \"Délai ordinaire :\\n• 3 jours francs pour communes < 3 500 hab.\\n• 5 jours francs pour les autres communes\\n\\nJours francs : ne comprennent ni le jour d'envoi, ni le jour de la réunion, ni samedis, dimanches, jours fériés.\\n\\nUrgence : délai réduit (minimum 1 jour franc). Le maire rend compte de l'urgence en ouverture de séance. Le conseil vote sur l'urgence. Le juge peut annuler si l'urgence n'est pas justifiée.\"\n    }, {\n      title: \"5. Information des conseillers\",\n      text: \"Droit d'information sur toutes les questions soumises à délibération.\\n\\nLe maire ne doit pas dissimuler d'informations utiles.\\n\\nMesures spéciales d'information :\\n• Projets de marchés publics (besoins, montant prévisionnel)\\n• Projets de contrats de service public\\n• Avis de la CRC et arrêtés du préfet sur le contrôle budgétaire\\n• Rapport d'observations de la CRC\"\n    }]\n  }, {\n    id: 12,\n    title: \"Le fonctionnement du conseil municipal\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Information collective des conseillers\",\n      text: \"\",\n      subsections: [{\n        title: \"1.1. Commissions\",\n        text: \"Le conseil peut former des commissions consultatives pour étudier les questions.\\n\\nCommunes ≥ 1 000 hab. : composition respectant la représentation proportionnelle.\"\n      }, {\n        title: \"1.2. Mission d'information et d'évaluation\",\n        text: \"Communes ≥ 50 000 hab. : le conseil peut créer une mission d'information sur une question d'intérêt communal.\\n\\nAucun conseiller ne peut s'y associer plus d'une fois par an.\"\n      }, {\n        title: \"1.3. Droits de l'opposition\",\n        text: \"Communes ≥ 3 500 hab. : espace réservé dans le bulletin municipal. Local gratuit pour les conseillers.\\n\\nCommunes ≥ 100 000 hab. : les groupes d'élus peuvent se constituer avec locaux, personnel et frais de fonctionnement.\"\n      }]\n    }, {\n      title: \"2. Organisation de la séance\",\n      text: \"\",\n      subsections: [{\n        title: \"Procuration, quorum et présidence\",\n        text: \"Procuration : un conseiller empêché peut donner procuration à un collègue (max 3 séances consécutives sauf maladie).\\n\\nQuorum : plus de la moitié de l'effectif doit être présent. Si non atteint : nouvelle convocation 3 jours plus tard, sans condition de quorum.\\n\\nPrésidence : le maire, sauf pour le compte administratif (le conseil élit son président) et la première séance (doyen d'âge).\"\n      }, {\n        title: \"Police, publicité et vote\",\n        text: \"Police des séances : le président peut expulser les fauteurs de troubles.\\n\\nPublicité : séances publiques (huis clos possible à la majorité absolue).\\n\\nVote : constat par le maire, scrutin public, ou scrutin secret (obligatoire pour nominations sauf unanimité contraire).\\n\\nMajorité : absolue des suffrages exprimés. Voix du président prépondérante en cas d'égalité (sauf scrutin secret).\"\n      }]\n    }, {\n      title: \"3. Mesures après la séance\",\n      text: \"Compte rendu : affiché en mairie + mis en ligne sous une semaine.\\n\\nRegistre des délibérations : inscrites par ordre de date, signées par tous les membres présents.\\n\\nRecueil des actes administratifs : communes ≥ 3 500 hab., publication papier ou électronique.\\n\\nAccès du public : toute personne peut demander communication des PV, budgets, comptes et arrêtés municipaux.\"\n    }]\n  }, {\n    id: 13,\n    title: \"L'exécution des décisions du conseil municipal\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Principes d'exécution\",\n      text: \"L'exécution est gouvernée par le principe de séparation entre l'ordonnateur et le comptable public, garantissant un contrôle des opérations financières et patrimoniales.\\n\\nLes dépenses suivent un schéma : engagement, liquidation, ordonnancement.\\nLes recettes : constatation du fait générateur, liquidation, ordonnancement des titres.\"\n    }, {\n      title: \"2. Publicité et transmission\",\n      text: \"Les actes sont transmis au contrôle de légalité du préfet.\\n\\nLe compte rendu est affiché en mairie et publié sur le site internet du commune sous une semaine.\\n\\nLes délibérations sont inscrites au registre par ordre de date.\\n\\nDans les communes ≥ 3 500 hab., les délibérations réglementaires sont publiées au recueil des actes administratifs.\"\n    }]\n  }, {\n    id: 14,\n    title: \"Le maire\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Agent de l'État dans la commune\",\n      text: \"Le maire exerce des fonctions au nom de l'État :\\n• Officier d'état civil (mariages, naissances, décès)\\n• Officier de police judiciaire\\n• Publication et exécution des lois et règlements\\n• Exécution des mesures de sûreté générale\\n• Organisation des élections\\n• Légalisation des signatures\"\n    }, {\n      title: \"2. Exécutif de la commune\",\n      text: \"Le maire est élu par le conseil municipal lors de sa première réunion. Durée du mandat : 6 ans.\\n\\nAttributions :\\n• Prépare et exécute les délibérations du conseil municipal\\n• Ordonnateur des dépenses et prescrit l'exécution des recettes\\n• Passe les marchés et signe les contrats\\n• Gère le patrimoine communal\\n• Représente la commune en justice\\n• Nomme aux emplois communaux\\n• Dirige les services municipaux\\n• Exerce le pouvoir de police municipale\"\n    }, {\n      title: \"3. Les pouvoirs propres du maire\",\n      text: \"Pouvoirs de police : le maire dispose de pouvoirs de police administrative pour assurer l'ordre public, la sécurité, la salubrité et la tranquillité.\\n\\nDélégations : le maire peut déléguer une partie de ses fonctions à un ou plusieurs adjoints et, en l'absence ou empêchement de ceux-ci, à des membres du conseil municipal.\\n\\nRelation cadre/élus : le DGS est le principal collaborateur du maire, assurant la direction de l'administration. La zone grise entre politique et administration est source de tensions mais aussi de coproduction de l'action publique.\"\n    }]\n  }, {\n    id: 15,\n    title: \"Les adjoints au maire\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Élection et rôle\",\n      text: \"Les adjoints sont élus par le conseil municipal. Leur nombre ne peut excéder 30% de l'effectif du conseil.\\n\\nIls suppléent le maire en cas d'absence ou d'empêchement, dans l'ordre de leur élection.\"\n    }, {\n      title: \"2. Attributions\",\n      text: \"Les compétences des adjoints sont attribuées par le maire via des délégations. Ils exercent des pouvoirs délégués par arrêté du maire.\\n\\nJuridiquement subordonnés au maire, ils entretiennent dans la pratique une relation étroite avec les fonctionnaires et peuvent parfois intervenir directement dans l'administration.\\n\\nLa loi impose qu'au moins un adjoint soit conseiller municipal.\"\n    }]\n  }, {\n    id: 16,\n    title: \"La commune nouvelle\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Création\",\n      text: \"La commune nouvelle résulte de la fusion de communes existantes. Elle peut être créée à l'initiative des conseils municipaux, de l'EPCI ou du préfet.\\n\\nCondition : accord des 2/3 au moins des conseils municipaux représentant plus des 2/3 de la population totale.\"\n    }, {\n      title: \"2. Fonctionnement\",\n      text: \"Des communes déléguées peuvent être maintenues sur le périmètre des anciennes communes. Elles disposent d'un maire délégué et d'une annexe de la mairie.\\n\\nLes communes nouvelles bénéficient d'avantages financiers (garantie de dotation pendant 3 ans).\"\n    }]\n  }, {\n    id: 17,\n    title: \"Les grandes étapes de l'intercommunalité\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Les origines (avant 1992)\",\n      text: \"• 1890 : création du syndicat intercommunal à vocation unique (SIVU)\\n• 1955 : syndicat mixte\\n• 1959 : syndicat intercommunal à vocation multiple (SIVOM)\\n• 1966 : création des communautés urbaines (loi du 31/12/1966)\"\n    }, {\n      title: \"2. Les lois structurantes\",\n      text: \"• Loi ATR (6 février 1992) : communautés de communes et de villes\\n• Loi Chevènement (12 juillet 1999) : simplification avec 3 structures (communauté de communes, d'agglomération, urbaine). Fiscalité propre, périmètre sans enclave, d'un seul tenant.\\n• Loi du 16 décembre 2010 : achèvement de la carte intercommunale, création des métropoles et pôles métropolitains\\n• Loi MAPTAM (27 janvier 2014) : métropoles à statut particulier (Grand Paris, Aix-Marseille, Lyon)\\n• Loi NOTRe (7 août 2015) : renforcement des intercommunalités (seuil de 15 000 hab. minimum), rationalisation des compétences\"\n    }]\n  }, {\n    id: 18,\n    title: \"Les grands principes de l'intercommunalité\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Principes fondamentaux\",\n      text: \"• Spécialité : les EPCI n'exercent que les compétences qui leur sont transférées\\n• Exclusivité : les compétences transférées ne peuvent plus être exercées par les communes membres\\n• Subsidiarité : les EPCI interviennent pour les compétences que les communes ne peuvent exercer seules efficacement\"\n    }, {\n      title: \"2. Intérêt communautaire\",\n      text: \"L'intérêt communautaire détermine la ligne de partage entre les compétences communales et intercommunales.\\n\\nIl est défini par le conseil communautaire à la majorité des 2/3 de ses membres.\\n\\nIl permet de distinguer les actions relevant de la compétence communautaire de celles restant au niveau communal.\"\n    }, {\n      title: \"3. Types de structures\",\n      text: \"Structures sans fiscalité propre : SIVU, SIVOM, syndicats mixtes\\n\\nStructures à fiscalité propre :\\n• Communauté de communes (seuil : 15 000 hab.)\\n• Communauté d'agglomération (50 000 hab.)\\n• Communauté urbaine (250 000 hab.)\\n• Métropole (400 000 hab.)\"\n    }]\n  }, {\n    id: 19,\n    title: \"Les différentes structures intercommunales\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Les EPCI à fiscalité propre\",\n      text: \"4 catégories principales ordonnées par niveau d'intégration :\\n\\n1. Communauté de communes : seuil de 15 000 hab., compétences obligatoires en aménagement de l'espace et développement économique.\\n\\n2. Communauté d'agglomération : 50 000 hab. avec commune-centre > 15 000 hab., compétences renforcées.\\n\\n3. Communauté urbaine : 250 000 hab., intégration forte avec nombreuses compétences obligatoires.\\n\\n4. Métropole : 400 000 hab., niveau d'intégration maximum. Compétences étendues (développement économique, aménagement, logement, politique de la ville, transports, environnement).\"\n    }]\n  }, {\n    id: 20,\n    title: \"Le département\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Le conseil départemental\",\n      text: \"Composition : conseillers départementaux élus pour 6 ans au scrutin majoritaire binominal paritaire à 2 tours dans le cadre du canton.\\n\\nChaque canton élit un binôme (1 femme, 1 homme). Pour être élu au 1er tour : majorité absolue + 25% des inscrits. Au 2e tour : majorité relative.\\n\\nFonctionnement : séances publiques (huis clos possible), délibérations à la majorité absolue des suffrages exprimés.\\n\\nDepuis la loi NOTRe (2015), le département a perdu la clause générale de compétence et ne conserve que des compétences d'attribution.\"\n    }, {\n      title: \"2. Le président du conseil départemental\",\n      text: \"Élu par le conseil départemental lors de sa première réunion.\\n\\nAttributions :\\n• Prépare et exécute les délibérations du conseil\\n• Ordonnateur des dépenses\\n• Préside les services du département\\n• Pouvoir de police administrative sur le domaine départemental\\n• Gère le domaine départemental\\n• Chef des services départementaux\"\n    }, {\n      title: \"3. Compétences du département\",\n      text: \"Compétences principales :\\n• Action sociale et médico-sociale (RSA, APA, PCH, PMI, ASE)\\n• Voirie départementale\\n• Collèges (construction, entretien)\\n• Transports scolaires (avant transfert aux régions pour interurbain)\\n• Aménagement rural\\n• Tourisme\\n• Culture (archives, bibliothèques départementales)\\n• Solidarité territoriale\"\n    }]\n  }, {\n    id: 21,\n    title: \"La région\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Institutions de la région\",\n      text: \"Assemblée régionale : conseillers régionaux élus pour 6 ans au scrutin de liste à 2 tours.\\n\\nPrésident du conseil régional : élu par l'assemblée lors de sa première réunion.\\n\\nConseil économique, social, environnemental et culturel (CESER) : assemblée consultative représentant les forces vives de la région.\\n\\nDepuis le 1er janvier 2016 : 12 régions métropolitaines + Corse.\"\n    }, {\n      title: \"2. Compétences de la région\",\n      text: \"Compétences principales (renforcées par la loi NOTRe 2015) :\\n• Développement économique : schéma régional (SRDEII), aides aux entreprises\\n• Aménagement du territoire : SRADDET (schéma prescriptif)\\n• Transports : TER, transports interurbains, transports scolaires\\n• Formation professionnelle et apprentissage\\n• Lycées : construction, entretien, fonctionnement\\n• Environnement : biodiversité, parcs naturels régionaux\\n• Culture et patrimoine\\n• Sport et tourisme\\n• Gestion des fonds européens\\n\\nLa région a perdu la clause générale de compétence (loi NOTRe) mais a vu ses compétences considérablement renforcées.\"\n    }]\n  }, {\n    id: 22,\n    title: \"Paris - Lyon - Marseille\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Le statut PLM\",\n      text: \"Paris, Lyon et Marseille ont un statut particulier (loi PLM du 31 décembre 1982).\\n\\nOrganisation en arrondissements (20 à Paris, 9 à Lyon, 16 à Marseille) ou secteurs (8 secteurs à Marseille regroupant les 16 arrondissements).\\n\\nConseil municipal : élu par secteur/arrondissement. Nombre de conseillers fixé par la loi.\\n\\nConseil d'arrondissement/secteur : composé de conseillers municipaux et de conseillers d'arrondissement. Mission de participation à l'administration locale.\\n\\nMaire d'arrondissement : élu par le conseil d'arrondissement, a des attributions propres et des pouvoirs de police délégués par le maire de la ville.\\n\\nLa loi du 28 février 2017 a créé la Ville de Paris comme collectivité à statut particulier, exerçant les compétences de la commune et du département.\"\n    }]\n  }, {\n    id: 23,\n    title: \"La collectivité de Corse\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Statut particulier\",\n      text: \"La Corse est une collectivité territoriale à statut particulier depuis le 1er janvier 2018 (fusion de la collectivité territoriale de Corse et des deux départements).\\n\\nInstitutions : Assemblée de Corse, Conseil exécutif de Corse, Conseil économique, social, environnemental et culturel.\\n\\nCompétences élargies : aménagement, développement économique, énergie, transports, éducation, culture, patrimoine, environnement.\"\n    }]\n  }, {\n    id: 24,\n    title: \"La métropole de Lyon\",\n    theme: 'environnement',\n    sections: [{\n      title: \"Statut de collectivité territoriale\",\n      text: \"Depuis le 1er janvier 2015, la métropole de Lyon est une collectivité territoriale à statut particulier (loi MAPTAM 2014).\\n\\nElle exerce les compétences de la communauté urbaine ET du département sur son territoire.\\n\\nConseil de la métropole : élu au suffrage universel direct depuis 2020.\\n\\nPrésident : ordonnateur des dépenses, chef des services.\"\n    }]\n  }, {\n    id: 25,\n    title: \"Les collectivités territoriales d'outre-mer\",\n    theme: 'environnement',\n    sections: [{\n      title: \"1. Collectivités de l'article 73 (DOM-ROM)\",\n      text: \"Guadeloupe, Martinique, Guyane, Réunion, Mayotte.\\n\\nPrincipe d'identité législative : les lois et règlements s'appliquent de plein droit, sous réserve d'adaptations.\\n\\nGuadeloupe et Réunion : conseil régional + conseil départemental séparés.\\nMartinique et Guyane : collectivité territoriale unique (assemblée unique depuis 2015).\\nMayotte : département depuis 2011.\"\n    }, {\n      title: \"2. Collectivités de l'article 74 (COM)\",\n      text: \"Saint-Barthélemy, Saint-Martin, Saint-Pierre-et-Miquelon, Polynésie française, Wallis-et-Futuna.\\n\\nPrincipe de spécialité législative : les lois ne s'appliquent que sur mention expresse.\\n\\nAutonomie variable selon les collectivités. Loi organique propre à chacune.\"\n    }, {\n      title: \"3. Statuts particuliers\",\n      text: \"Nouvelle-Calédonie : titre XIII de la Constitution, transferts progressifs de compétences, possibilité d'accession à la pleine souveraineté (3 référendums : 2018, 2020, 2021).\\n\\nTerres australes et antarctiques françaises (TAAF) : administration directe par l'État.\"\n    }]\n  }];\n});","lineCount":281,"map":[[7,2,5,0,"Object"],[7,8,5,0],[7,9,5,0,"defineProperty"],[7,23,5,0],[7,24,5,0,"exports"],[7,31,5,0],[8,4,5,0,"enumerable"],[8,14,5,0],[9,4,5,0,"get"],[9,7,5,0],[9,18,5,0,"get"],[9,19,5,0],[10,6,5,0],[10,13,5,0,"fichesCollectivites"],[10,32,5,0],[11,4,5,0],[12,2,5,0],[13,2,3,0],[15,2,5,7],[15,8,5,13,"fichesCollectivites"],[15,27,5,41],[15,30,5,44],[15,31,6,2],[16,4,6,4,"id"],[16,6,6,6],[16,8,6,8],[16,9,6,9],[17,4,6,11,"title"],[17,9,6,16],[17,11,6,18],[17,52,6,59],[18,4,6,61,"theme"],[18,9,6,66],[18,11,6,68],[18,26,6,83],[19,4,6,85,"sections"],[19,12,6,93],[19,14,6,95],[19,15,7,4],[20,6,7,6,"title"],[20,11,7,11],[20,13,7,13],[20,40,7,40],[21,6,7,42,"text"],[21,10,7,46],[21,12,7,48],[22,4,7,500],[22,5,7,501],[23,2,8,3],[23,3,8,4],[23,5,9,2],[24,4,9,4,"id"],[24,6,9,6],[24,8,9,8],[24,9,9,9],[25,4,9,11,"title"],[25,9,9,16],[25,11,9,18],[25,58,9,65],[26,4,9,67,"theme"],[26,9,9,72],[26,11,9,74],[26,26,9,89],[27,4,9,91,"sections"],[27,12,9,99],[27,14,9,101],[27,15,10,4],[28,6,10,6,"title"],[28,11,10,11],[28,13,10,13],[28,70,10,70],[29,6,10,72,"text"],[29,10,10,76],[29,12,10,78],[29,14,10,80],[30,6,10,82,"subsections"],[30,17,10,93],[30,19,10,95],[30,20,11,6],[31,8,11,8,"title"],[31,13,11,13],[31,15,11,15],[31,41,11,41],[32,8,11,43,"text"],[32,12,11,47],[32,14,11,49],[33,6,11,774],[33,7,11,775],[33,9,12,6],[34,8,12,8,"title"],[34,13,12,13],[34,15,12,15],[34,61,12,61],[35,8,12,63,"text"],[35,12,12,67],[35,14,12,69],[36,6,12,401],[36,7,12,402],[37,4,13,5],[37,5,13,6